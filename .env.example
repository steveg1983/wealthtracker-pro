# WealthTracker environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local.
#
# SECURITY RULE: VITE_-prefixed variables are inlined into the public browser
# bundle by Vite. Only publishable/anon keys may use the VITE_ prefix.
# Server-side secrets (service-role, Clerk secret, Stripe secret, encryption
# keys) must NOT have a VITE_ prefix and are read via process.env in api/.

# --- Client-safe (public) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_SENTRY_DSN=

# --- Server-only secrets (no VITE_ prefix — never bundled) ---
CLERK_SECRET_KEY=sk_test_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
ENCRYPTION_KEY=
BANKING_STATE_SECRET=

# --- TrueLayer (server-only) ---
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=
TRUELAYER_ENVIRONMENT=sandbox
