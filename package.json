{
  "name": "wealth-tracker",
  "private": true,
  "version": "1.4.5",
  "type": "module",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:vite": "vite",
    "build": "node scripts/verify-server-env.mjs && vite build",
    "build:check": "tsc -b && vite build",
    "build:bypass": "vite build --mode production",
    "build:lenient": "tsc -p tsconfig.lenient.json --noEmit && vite build",
    "build:compress": "node scripts/build-with-compression.js",
    "build:production": "npm run build:compress",
    "build:sw": "node scripts/build-service-worker.js",
    "optimize:images": "node scripts/optimize-images.js",
    "perf:analyze": "node scripts/run-performance-tests.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "test:direct": "node scripts/run-tests-direct.mjs",
    "test:batched": "node scripts/run-all-tests.mjs",
    "test:unit": "vitest run --exclude='**/integration/**'",
    "test:integration": "vitest run src/test/integration",
    "test:realtime": "node scripts/run-realtime-suite.mjs",
    "test:e2e": "playwright test",
    "test:e2e:journeys": "playwright test e2e/journeys",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "cypress": "cypress open",
    "cypress:run": "cypress run",
    "cypress:headless": "cypress run --headless",
    "cypress:component": "cypress open --component",
    "sync:server": "node sync-server.js",
    "dev:sync": "concurrently \"npm run dev\" \"npm run sync:server\"",
    "bench": "vitest bench",
    "bench:run": "vitest bench --run",
    "bundle:check": "node scripts/bundle-size-check.mjs",
    "bundle:report": "node scripts/bundle-size-check.mjs --report",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "perf:test": "npm run build && npm run bundle:check && npm run lighthouse",
    "test:analyze": "node scripts/test-coverage-analysis.js",
    "test:generate": "node scripts/generate-test-templates.js high-priority",
    "test:generate:single": "node scripts/generate-test-templates.js single",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc -b",
    "test:smoke": "vitest run",
    "handoff:update": "echo 'No handoff snapshots configured'",
    "test:supabase-smoke": "RUN_SUPABASE_REAL_TESTS=true node scripts/run-supabase-smoke.mjs",
    "banking:smoke": "node scripts/run-banking-api-smoke.mjs",
    "banking:rollout": "bash scripts/apply-banking-ops-rollout.sh",
    "db:migrate": "supabase db push --include-roles --include-policies --db-url \"$SUPABASE_DB_URL\"",
    "db:migration:new": "supabase migration new",
    "db:diff": "supabase db diff --schema public --file supabase/migrations/$(date +%Y%m%d%H%M)__schema-diff.sql",
    "db:lint": "supabase db lint --linked --fail-on error",
    "db:reset": "supabase db reset --db-url \"$SUPABASE_DB_URL\"",
    "deploy": "./deploy.sh",
    "deploy:prod": "./deploy.sh prod",
    "vercel:login": "vercel login",
    "vercel:link": "vercel link",
    "vercel:env": "vercel env pull",
    "env:doctor": "node --loader ts-node/esm scripts/env-doctor.ts",
    "setup": "npm run env:doctor",
    "verify:pre-commit": "npm run build:check && npm run lint && npm run test:unit",
    "verify:full": "npm run typecheck:strict && npm run build:check && npm run lint && npm run test:unit && npm run test:realtime && npm run test:coverage && node scripts/verify-coverage-threshold.mjs coverage/coverage-final.json --statements=63 --branches=55",
    "audit:data": "node scripts/audit-data-integrity.mjs",
    "backup:db": "node scripts/backup-database.mjs",
    "restore:db": "node scripts/restore-database.mjs",
    "dr:drill": "node scripts/dr-restore-drill.mjs",
    "pentest": "node scripts/pentest.mjs",
    "audit:a11y": "node scripts/audit-accessibility.mjs",
    "audit:data:repair": "node scripts/repair-balance-drift.mjs",
    "verify:financial": "node scripts/verify-financial-safety.mjs",
    "verify:bundle": "npm run build && node scripts/bundle-size-check.mjs",
    "verify:types": "node scripts/verify-type-safety.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/backend": "^3.6.1",
    "@clerk/clerk-react": "^5.61.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/node": "^10.67.0",
    "@sentry/react": "^10.67.0",
    "@stripe/react-stripe-js": "^3.9.0",
    "@stripe/stripe-js": "^7.8.0",
    "@supabase/supabase-js": "^2.55.0",
    "@tabler/icons-react": "^3.34.1",
    "@types/crypto-js": "^4.2.2",
    "@types/dompurify": "^3.0.5",
    "@types/jspdf": "^1.3.3",
    "@types/react-window": "^1.8.8",
    "@types/uuid": "^10.0.0",
    "ag-grid-community": "^34.1.2",
    "ag-grid-react": "^34.1.2",
    "buffer": "^6.0.3",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.2.6",
    "es-toolkit": "^1.39.9",
    "framer-motion": "^12.23.12",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "mdb-reader": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.2",
    "react-router-dom": "^7.6.3",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-window": "^1.8.11",
    "react-window-infinite-loader": "^1.0.10",
    "recharts": "^3.1.2",
    "regression": "^2.0.1",
    "simple-statistics": "^7.8.8",
    "stripe": "^18.4.0",
    "tesseract.js": "^6.0.1",
    "uuid": "^11.1.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@clerk/types": "^4.101.20",
    "@eslint/js": "^9.30.1",
    "@faker-js/faker": "^10.1.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.54.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/decimal.js": "^0.0.32",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/react-grid-layout": "^1.3.5",
    "@vercel/node": "^5.5.10",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.17",
    "c8": "^10.1.3",
    "canvas": "^3.1.2",
    "compression": "^1.8.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "express": "^5.1.0",
    "fake-indexeddb": "^6.0.1",
    "glob": "^11.0.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "idb": "^8.0.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.43.1",
    "ts-node": "^10.9.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vercel": "^54.11.1",
    "vite": "^7.0.4",
    "vite-plugin-compression2": "^2.2.0",
    "vitest": "^3.2.4",
    "workbox-background-sync": "^7.3.0",
    "workbox-broadcast-update": "^7.3.0",
    "workbox-cacheable-response": "^7.3.0",
    "workbox-expiration": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  }
}
